# Postgres credentials used by both the postgres container and the api connection string.
POSTGRES_USER=prodx
POSTGRES_PASSWORD=prodx
POSTGRES_DB=prodx

# Used when running the API directly on the host (outside compose).
DATABASE_URL=postgresql+psycopg://prodx:prodx@localhost:5432/prodx
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=60

# Allowed browser origins (comma separated).
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://127.0.0.1:8080,http://127.0.0.1:5173
